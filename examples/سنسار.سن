# ==========================================
# سنڌي (SindhiScript) - سنسار (The World)
# هي هڪ جامع مثال آهي جيڪو ٻوليءَ جي خصوصيتن کي ڏيکاري ٿو.
# ==========================================

ڇاپ("--- سنڌي پروگرامنگ جي دنيا ۾ ڀليڪار ---")

# 1. متغير ۽ ثابت (Variables and Constants)
متغير نالو = "سنسار"
ثابت پائي = 3.14159

ڇاپ("نالو: "، نالو)
ڇاپ("پائي جو قدر: "، پائي)

# 2. حساب ۽ فنڪشن (Math and Functions)
ڪم گولائي(ريڊيس):
    موٽايو 2 ضرب پائي ضرب ريڊيس

متغير نتيجو = گولائي(10)
ڇاپ("10 ريڊيس واري دائري جي گولائي آهي: "، نتيجو)

# 3. لوپ ۽ شرط (Loops and Conditions)
ڇاپ("--- 1 کان 5 تائين ڳڻپ ---")
متغير ڳڻپ = 1
جڏهن_تائين ڳڻپ گهٽ_برابر 5:
    جيڪڏهن ڳڻپ باقي 2 برابر 0:
        ڇاپ(ڳڻپ، "هڪ ٻڌي (Even) عدد آهي")
    نه_ته:
        ڇاپ(ڳڻپ، "هڪ ايڪي (Odd) عدد آهي")
    ڳڻپ = ڳڻپ جمع 1

# 4. فهرستون (Lists and iteration)
ڇاپ("--- ميون جي لسٽ ---")
متغير ميوا = ["انب"، "ڪيلو"، "صوف"]
شامل_ڪرو(ميوا، "زيتون")

هر ميوو ۾ ميوا:
    ڇاپ("ميوو: "، ميوو)

# 5. او او پي (OOP: Classes and Inheritance)
ڇاپ("--- طبقو ۽ ورثو (Classes and Inheritance) ---")
طبقو جانور:
    ڪم پيدائش(نالو، عمر):
        پنهنجو.نالو = نالو
        پنهنجو.عمر = عمر

    ڪم آواز_ڪرو():
        ڇاپ("ڪو آواز")

طبقو پکي ورثو جانور:
    ڪم آواز_ڪرو():
        ڇاپ(پنهنجو.نالو، "چوي ٿو: چُون چُون!")

متغير طوطو = پکي("مٺو طوطو"، 2)
ڇاپ("پکي جو نالو: "، طوطو.نالو)
طوطو.آواز_ڪرو()

# 6. پائيٿون سان رابطو (FFI - Foreign Function Interface)
ڇاپ("--- ٻاهريون ڪم (FFI) ---")
ٻاهري ڪم سسٽم_معلومات():
    import platform
    return platform.platform()

ڇاپ("سسٽم جي ڄاڻ: "، سسٽم_معلومات())

ڇاپ("--- پروگرام ختم ٿيو ---")
